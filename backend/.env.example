# PostgreSQL connection string
DATABASE_URL=postgresql://myuser:mysecurepassword@otaship_db/otaship

# Cloudinary credentials
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=

# AWS S3 credentials
S3_ACCESS_KEY=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET_NAME=
S3_ENDPOINT=
S3_BASE_PATH=

# Admin access token hash
ADMIN_TOKEN_HASH=hash_of_a_strong_token_here

# Server configuration
PORT=8080

# CORS allowed origins (comma-separated, defaults to * if not set)
ALLOWED_ORIGINS=*

EXPO_PRIVATE_KEY=""

LOG_FORMAT=text
LOG_LEVEL=debug
